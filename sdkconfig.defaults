CONFIG_COMPILER_CXX_EXCEPTIONS=y
CONFIG_COMPILER_CXX_RTTI=y
CONFIG_COMPILER_CXX_STD_23=y
CONFIG_ESP_TIMER_SUPPORTS_ISR_DISPATCH_METHOD=y
